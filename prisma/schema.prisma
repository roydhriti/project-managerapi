
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}



model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  email       String   @unique
  password    String
  name        String
  provider    String   @default("local")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}